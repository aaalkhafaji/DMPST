import numpy as np
import cv2
from skimage import data
from skimage.metrics import peak_signal_noise_ratio as calculate_psnr
from skimage.metrics import structural_similarity as calculate_ssim
from skimage.util import random_noise

def apply_multiscale_mpo(noisy_image):
    """
    Implements the Multi-Scale MPO Framework to prevent the Edge Detection Paradox.
    Relies entirely on comparator-tree logic (Min/Max/Rank) for O(1) hardware mapping.
    """
    # 1. Rank-Order Baseline (Approximating the Multi-Scale Comparator Tree)
    # This annihilates impulse noise so it isn't misclassified as an edge.
    base_denoised = cv2.medianBlur(noisy_image, 3)
    
    # 2. Compute the True Edge Confidence Map E(x)
    # Applied to the clean baseline to isolate physical geometry, not stochastic noise.
    kernel = np.ones((3, 3), np.uint8)
    dilation = cv2.dilate(base_denoised, kernel)
    erosion = cv2.erode(base_denoised, kernel)
    edge_map = cv2.subtract(dilation, erosion)
    
    # 3. Generate the Adaptive Blending Mask (alpha)
    # Normalizes the edge map to smoothly gate the temporal update
    alpha = edge_map.astype(np.float32) / 255.0
    alpha = np.clip(alpha * 1.5, 0, 1) # Boost to strictly lock sharp edges
    
    # 4. Partial Morphological Evolution (Fusion)
    # Flat regions (alpha ~ 0) receive the aggressive noise annihilation
    # Edge regions (alpha ~ 1) retain high-frequency structural fidelity
    restored = (base_denoised.astype(np.float32) * (1.0 - alpha)) + \
               (noisy_image.astype(np.float32) * alpha)
               
    # Apply a final light rank-filter to clean noise sitting directly on edges
    final_output = cv2.medianBlur(restored.astype(np.uint8), 3)
    
    return final_output

# --- Load Image & Add Noise ---
img = data.camera()

print("=== FINAL NOISE ROBUSTNESS BENCHMARK (MULTI-SCALE MPO) ===")

# 1. Salt & Pepper Test (10%)
sp_noisy = (random_noise(img, mode='s&p', amount=0.10) * 255).astype(np.uint8)
sp_restored = apply_multiscale_mpo(sp_noisy)
print(f"Salt & Pepper -> PSNR: {calculate_psnr(img, sp_restored):.2f} dB | SSIM: {calculate_ssim(img, sp_restored, data_range=255):.4f}")

# 2. Speckle Test (var=0.05)
speckle_noisy = (random_noise(img, mode='speckle', var=0.05) * 255).astype(np.uint8)
speckle_restored = apply_multiscale_mpo(speckle_noisy)
print(f"Speckle       -> PSNR: {calculate_psnr(img, speckle_restored):.2f} dB | SSIM: {calculate_ssim(img, speckle_restored, data_range=255):.4f}")

# 3. Poisson Test
poisson_noisy = (random_noise(img, mode='poisson') * 255).astype(np.uint8)
poisson_restored = apply_multiscale_mpo(poisson_noisy)
print(f"Poisson       -> PSNR: {calculate_psnr(img, poisson_restored):.2f} dB | SSIM: {calculate_ssim(img, poisson_restored, data_range=255):.4f}")

# 4. Mixed Noise (Gauss + S&P)
mixed = random_noise(img, mode='gaussian', var=0.005)
mixed = (random_noise(mixed, mode='s&p', amount=0.05) * 255).astype(np.uint8)
mixed_restored = apply_multiscale_mpo(mixed)
print(f"Mixed Noise   -> PSNR: {calculate_psnr(img, mixed_restored):.2f} dB | SSIM: {calculate_ssim(img, mixed_restored, data_range=255):.4f}")
